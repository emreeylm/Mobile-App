# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bingedate

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — en az 32 karakter rastgele string zorunlu (ör: openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_STRONG_32_CHAR_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# TMDB
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# Google OAuth
GOOGLE_CLIENT_ID=

# Apple
APPLE_TEAM_ID=
APPLE_CLIENT_ID=

# APNs Push Bildirim (.p8 dosyası içeriği — satır sonlarını \n ile birleştir)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=com.yourcompany.bingedate
APNS_PRODUCTION=false

# AdMob SSV imza doğrulama
ADMOB_SECRET_KEY=

# Fotoğraf depolama: "local" (disk) veya "s3" (AWS S3 / Cloudflare R2)
STORAGE_BACKEND=local
UPLOAD_DIR=/tmp/bingedate_photos

# S3 yapılandırması (STORAGE_BACKEND=s3 iken gerekli)
S3_BUCKET=
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BASE_URL=   # CDN URL, ör: https://cdn.yourdomain.com

# CORS — üretimde kısıtlayın
ALLOWED_ORIGINS=["*"]
