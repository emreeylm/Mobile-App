# ============================================================
# BINGE DATE — Üretim Ortamı Değişkenleri
# Bu dosya Render dashboard'daki "Environment" sekmesine girilir.
# ============================================================

# --- Supabase PostgreSQL (Direct Connection) ---
# Supabase → Project Settings → Database → Connection string → URI
# "Transaction pooler" değil, "Direct connection" kullan (Alembic uyumluluğu)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_SSL=true

# --- Upstash Redis ---
# Upstash Console → Database → REST API → Redis URL (rediss://)
REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6379

# --- JWT (Render otomatik üretir, render.yaml'da generateValue:true) ---
JWT_SECRET=                        # Render doldurur, elle girme
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- TMDB ---
TMDB_API_KEY=                      # https://www.themoviedb.org/settings/api

# --- Supabase Storage (fotoğraf yükleme) ---
STORAGE_BACKEND=s3
S3_BUCKET=photos                   # Supabase Storage'da oluşturduğun bucket adı
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=                 # Supabase → Storage → S3 Access Keys → Access Key ID
AWS_SECRET_ACCESS_KEY=             # Supabase → Storage → S3 Access Keys → Secret Key
S3_ENDPOINT_URL=https://[PROJECT-REF].supabase.co/storage/v1/s3
S3_BASE_URL=https://[PROJECT-REF].supabase.co/storage/v1/object/public/photos

# --- APNs Push (sonra eklenebilir) ---
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=
APNS_PRODUCTION=false

# --- CORS ---
ALLOWED_ORIGINS=["*"]
